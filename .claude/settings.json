{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(**)",
      "PowerShell(*)",
      "Agent(**)",
      "Skill(**)",
      "mcp__serena__*",
      "mcp__plugin_context7_context7__*"
    ]
  },
  "spinnerTipsEnabled": false,
  "enabledMcpjsonServers": [
    "serena-online"
  ],
  "enabledPlugins": {
    "caveman@caveman": false,
    "context7@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true
  },
  "language": "Taiwan",
  "autoUpdatesChannel": "stable",
  "theme": "dark",
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "codex開工",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \".claude/scripts/_pipeline_trigger.ps1\""
          }
        ]
      },
      {
        "matcher": "開工",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \".claude/scripts/_pipeline_trigger.ps1\""
          }
        ]
      },
      {
        "matcher": "同步",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \".claude/scripts/_sync.ps1\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"try { (New-Object System.Media.SoundPlayer 'C:\\odoo\\.claude\\tools\\notice.wav').PlaySync() } catch {}\"",
            "statusMessage": "Claude waiting for input..."
          }
        ]
      }
    ]
  }
}
